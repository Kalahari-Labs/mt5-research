# market-intel configuration — copy to .env and fill in. NEVER commit .env.

# Collection cadence
INTEL_CYCLE_SEC=300
INTEL_NEWS_EVERY_N=3

# Alerting
INTEL_ALERT_AFTER=3
INTEL_ALERT_WEBHOOK=
INTEL_STALE_MIN=20

# Storage: leave empty for local SQLite; set both to use your own Supabase project
# (run migrations/0001_init.sql there first)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Optional extra news source (newsapi.org free tier: 100 requests/day)
NEWSAPI_KEY=

# ---------------- executor plane (see executor/EXECUTOR.md) ----------------
# Universe & cadence
MI_SYMBOLS=EURUSD,GBPUSD,USDJPY,GOLD
MI_TIMEFRAME=H1
MI_CYCLE_SEC=30

# Mode: trade (demo-gated server-side regardless) | observe (no orders ever)
MI_EXEC_MODE=trade

# Risk
MI_RISK_PER_TRADE_PCT=0.5
MI_MAX_DAILY_LOSS_PCT=2.0
MI_MAX_DRAWDOWN_PCT=10.0
MI_MAX_OPEN_POSITIONS=2
MI_MAX_ORDER_VOLUME=0.50
MI_MAX_HOLD_BARS=48
MI_NEWS_BLACKOUT_MIN=30

# Backtest gate (thresholds a combo must pass OOS before it may trade)
MI_GATE_MIN_TRADES=25
MI_GATE_MIN_PF_OOS=1.05
MI_GATE_MIN_EXPECTANCY_R=0.02
MI_GATE_MAX_DD_PCT=25
MI_GATE_REFRESH_HOURS=24
# stability: must be profitable in >= MIN_OK of SEGMENTS sequential time slices
MI_GATE_STABILITY_SEGMENTS=3
MI_GATE_STABILITY_MIN_OK=2

# Costs used by the backtest gate (raw/ECN accounts charge commission)
MI_COMMISSION_PER_LOT=0.0

# Phone notifications on entries/exits/halts (optional; pick one or both)
# ntfy: pick a LONG RANDOM topic, subscribe to it in the ntfy app (ntfy.sh)
MI_NTFY_TOPIC=
MI_TELEGRAM_BOT_TOKEN=
MI_TELEGRAM_CHAT_ID=

# Wine / bridge (defaults match the reference setup)
#MI_WINEPREFIX=/home/you/.mt5
#MI_BRIDGE_HOST=127.0.0.1
#MI_BRIDGE_PORT=8787
#MI_BRIDGE_SPAWN=1      # 0 = bridge runs elsewhere (Docker engine / remote host)
#MI_DASH_HOST=127.0.0.1 # 0.0.0.0 exposes the dashboard on your LAN
#MI_DASH_PORT=8877

# LIVE UNLOCK — leave this alone. See executor/EXECUTOR.md before touching it.
#MI_ALLOW_LIVE=0
