# Copy to .env and edit. Every value has a safe default in config.py.

# --- Strategy ---
STRATEGY_NAME=sma_crossover   # key into the strategies/ registry (sma_crossover | buy_and_hold | ...)
SYMBOL=EURUSD
TIMEFRAME_MIN=60          # 1,5,15,30,60,240,1440
SMA_FAST=20              # default params for sma_crossover
SMA_SLOW=50

# --- Risk (deterministic, enforced in risk.py) ---
RISK_PER_TRADE_PCT=1.0
MAX_DAILY_LOSS_PCT=3.0
MAX_OPEN_POSITIONS=1
DEFAULT_STOP_DISTANCE=0.0050   # price units used to size positions (50 pips on EURUSD)

# --- Backtest ---
INITIAL_CASH=10000
EXPOSURE=1.0
ALLOW_SHORT=true
COMMISSION_PER_SIDE=0.00007    # LEGACY proxy only (audit comparison); realistic uses the costs below

# --- Realistic cost model (the default; see FILL_MODEL.md) ---
SPREAD_PIPS=0.8                # ⚠ set to YOUR broker's typical EURUSD spread
COMMISSION_PER_LOT=3.5         # account ccy, per 1.0 lot, PER SIDE
SLIPPAGE_PIPS=0.2
FILL_TIMING=next_open          # next_open = realistic; close = look-ahead (audit only)

# --- Walk-forward validation ---
WF_IS_BARS=3000                # ~6 months of H1
WF_OOS_BARS=500                # ~1 month of H1
WF_STEP=500                    # roll by OOS size (no overlap)
WF_MIN_TRADES=30               # min in-sample trades for a param set to qualify

# --- Execution (DEMO ONLY) ---
# Default is OFF + dry-run. BOTH of these must change to send a live demo order,
# and execution.py still hard-refuses anything that is not a DEMO account.
EXECUTION_ENABLED=false
DRY_RUN=true

# --- Journal (optional) ---
# If both are set AND the supabase package is installed, the journal uses
# Supabase; otherwise it uses local SQLite at data/journal.sqlite.
# SUPABASE_URL=
# SUPABASE_KEY=
